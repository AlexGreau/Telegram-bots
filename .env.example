# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Logging
LOG_LEVEL=INFO

# Optional: Enable debug mode
DEBUG=False

# CONNEXIONS API Configuration
NOTION_API_KEY=blabla
# Claude API (for /assist command)
