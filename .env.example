# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Logging
LOG_LEVEL=INFO

# Optional: Enable debug mode
DEBUG=False

# CONNEXIONS API Configuration
NOTION_API_KEY=blabla
# Claude API (for /assist command)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Comma-separated Telegram user IDs allowed to use /assist
# Find your ID by messaging @userinfobot on Telegram
ASSIST_ALLOWED_IDS=123456789,987654321

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
GOOGLE_SHEET_ID_SWIM=your_swim_sheet_id
GOOGLE_SHEET_ID_RUN=your_run_sheet_id
